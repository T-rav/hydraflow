# Dockerfile.agent — Hydra agent container image
#
# Thin layer on top of the pre-built base image. Rebuilds in seconds
# since all heavy dependencies live in hydraflow-agent-base.
#
# Build:  docker build -f Dockerfile.agent -t ghcr.io/t-rav/hydraflow-agent:latest .
# Test:   docker run --rm ghcr.io/t-rav/hydraflow-agent:latest bash /opt/hydraflow/docker-smoke-test.sh

ARG BASE_IMAGE=ghcr.io/t-rav/hydraflow-agent-base:latest
FROM ${BASE_IMAGE}

# Copy smoke test script
COPY scripts/docker-smoke-test.sh /opt/hydraflow/docker-smoke-test.sh

CMD ["bash"]
